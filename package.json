{
  "name": "mcp-twitter",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Twitter API integration",
  "main": "dist/server.js",
  "bin": {
    "mcp-twitter": "dist/server.js"
  },
  "scripts": {
    "build": "node build.js",
    "dev": "nodemon --watch src --exec 'npm run build'",
    "start": "node dist/server.js",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "twitter",
    "twitter-api",
    "twitter-v2",
    "ai",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "axios": "^1.7.9",
    "dotenv": "^16.5.0",
    "twitter-api-v2": "^1.28.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^24.0.3",
    "esbuild": "^0.25.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nitaiaharoni1/twitter-mcp.git"
  }
}
